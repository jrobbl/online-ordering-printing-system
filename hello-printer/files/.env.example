# ============================================================
# .env — Raspberry Pi environment variables
# hello-printer/
#
# IMPORTANT:
#   - Never commit this file to git
#   - File permissions should be restricted: chmod 600 .env
#   - API_URL must match your laptop/VPS IP or domain
#   - ADMIN credentials must match backend/.env on the server
# ============================================================

# URL of the Express API
# Local development: your laptop's IP on the shared network
# Production: your Hostinger domain (Phase 7)
API_URL=http://10.x.x.x:3000

# Admin credentials — must match server's ADMIN_USERNAME
# and the password used when running setup-admin.js
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_password_here

# Printer device path
# Testing without printer: use a temp file
# Demo day: use the actual device
PRINTER_DEVICE=/tmp/ticket_test.bin
