# ============================================================
# backend/.env.example
# Copy to .env (dev) or .env.production (VPS) and fill values.
# Never commit the real files — this template is safe to commit.
# ============================================================

# --- Database ---
# Docker (production): DB_HOST must be "postgres" (service name)
# Local dev (no Docker): DB_HOST=localhost
DB_HOST=postgres
DB_PORT=5432
DB_NAME=oos_db
DB_USER=oos_admin
DB_PASSWORD=change_me

# --- Server ---
PORT=3000
# Use "production" on VPS, "development" locally
NODE_ENV=production

# --- CORS ---
# Production: your actual domain (must match what browser sees)
# Dev: not used (CORS is open with *)
ALLOWED_ORIGIN=https://yourdomain.com

# --- Admin credentials ---
ADMIN_USERNAME=emmer_admin
# Generate hash: node setup-admin.js
ADMIN_PASSWORD_HASH=run_setup_admin_to_generate

# --- JWT ---
# Generate: openssl rand -base64 64
JWT_SECRET=change_me_generate_with_openssl

# --- Business logic (optional — these are the defaults) ---
ORDER_HOUR_START=4
ORDER_HOUR_END=23
RECENT_ORDER_MINUTES=30
